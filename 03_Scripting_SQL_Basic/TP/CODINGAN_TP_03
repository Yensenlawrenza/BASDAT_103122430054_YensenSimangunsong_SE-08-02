CREATE TABLE mahasiswa (
    id NUMBER PRIMARY KEY,
    nama VARCHAR2(50),
    tempat_lahir VARCHAR2(50),
    tanggal_lahir DATE,
    nomor_hp VARCHAR2(15),
    email VARCHAR2(50),
    tinggi_badan NUMBER,
    berat_badan NUMBER
);

