SELECT * FROM mahasiswa;

SELECT nama,
       LOWER(nama) AS nama_lower,
       UPPER(nama) AS nama_upper
FROM mahasiswa;



SELECT nama,
       INITCAP(nama) AS nama_capital
FROM mahasiswa;

SELECT CONCAT(nama,' Mahasiswa') AS keterangan
FROM mahasiswa;

SELECT nama,
       LENGTH(nama) AS panjang_nama
FROM mahasiswa;

SELECT nama,
       SUBSTR(nama,1,3) AS potongan_nama
FROM mahasiswa;

SELECT 
LPAD(nama,10,'*') AS lpad_nama,
RPAD(nama,10,'*') AS rpad_nama
FROM mahasiswa;

SELECT 
LTRIM('   '||nama) AS ltrim_nama,
RTRIM(nama||'   ') AS rtrim_nama
FROM mahasiswa;

SELECT nama,
INSTR(nama,'a') AS posisi_huruf
FROM mahasiswa;

SELECT email,
REPLACE(email,'gmail','yahoo') AS email_baru
FROM mahasiswa;

SELECT 
TO_CHAR(tanggal_lahir,'MM') AS bulan_angka,
TO_CHAR(tanggal_lahir,'MON') AS bulan_singkat,
TO_CHAR(tanggal_lahir,'MONTH') AS bulan_lengkap
FROM mahasiswa;

SELECT 
TO_CHAR(tanggal_lahir,'DD') AS tanggal,
TO_CHAR(tanggal_lahir,'DY') AS hari_singkat
FROM mahasiswa;

SELECT 
nama,
TO_CHAR(tanggal_lahir,'YYYY') AS tahun_lengkap,
TO_CHAR(tanggal_lahir,'YY') AS tahun_pendek,
TO_CHAR(tanggal_lahir,'RR') AS format_rr
FROM mahasiswa;

SELECT 
TO_CHAR(SYSDATE,'HH') AS jam_12,
TO_CHAR(SYSDATE,'HH24') AS jam_24,
TO_CHAR(SYSDATE,'MI') AS menit,
TO_CHAR(SYSDATE,'SS') AS detik,
TO_CHAR(SYSDATE,'AM') AS am_pm
FROM dual;

SELECT SYSDATE FROM dual;

SELECT 
nama,
tanggal_lahir,
ADD_MONTHS(tanggal_lahir,6) AS tambah_6_bulan
FROM mahasiswa;

SELECT 
nama,
tanggal_lahir,
LAST_DAY(tanggal_lahir) AS akhir_bulan
FROM mahasiswa;

SELECT 
nama,
tanggal_lahir,
NEXT_DAY(tanggal_lahir,'MONDAY') AS senin_berikutnya
FROM mahasiswa;

SELECT 
nama,
tanggal_lahir,
MONTHS_BETWEEN(SYSDATE,tanggal_lahir) AS selisih_bulan
FROM mahasiswa;

SELECT 
nama,
tanggal_lahir,
ROUND(MONTHS_BETWEEN(SYSDATE,tanggal_lahir)) AS selisih_bulan
FROM mahasiswa;

SELECT 
nama,
ROUND(tanggal_lahir,'MONTH') AS pembulatan_bulan
FROM mahasiswa;

SELECT 
nama,
ROUND(tanggal_lahir,'YEAR') AS pembulatan_tahun
FROM mahasiswa;

SELECT 
TO_NUMBER('12345') AS hasil_konversi
FROM dual;

SELECT 
nama,
tanggal_lahir,
TO_CHAR(tanggal_lahir,'DD-MON-YYYY') AS tanggal_format
FROM mahasiswa;

SELECT 
nama,
tinggi_badan,
TO_CHAR(tinggi_badan) AS tinggi_text
FROM mahasiswa;

SELECT 
nama,
TO_CHAR(tanggal_lahir,'DAY, DD MONTH YYYY') AS tanggal_lahir_format
FROM mahasiswa;

SELECT 
nama,
berat_badan,
ABS(berat_badan) AS nilai_absolut
FROM mahasiswa;

SELECT 
nama,
tinggi_badan,
MOD(tinggi_badan,10) AS sisa_pembagian
FROM mahasiswa;

SELECT 
nama,
tinggi_badan,
FLOOR(tinggi_badan/10) AS pembulatan_bawah
FROM mahasiswa;

SELECT 
nama,
tinggi_badan,
POWER(tinggi_badan,2) AS tinggi_pangkat
FROM mahasiswa;

SELECT 
nama,
berat_badan,
ROUND(berat_badan/3,2) AS hasil_pembulatan
FROM mahasiswa;
